# ── NexusAI environment configuration ──────────────────────────────────────
# Copy this file to .env and fill in the values before starting the stack.

# ── Dashboard ───────────────────────────────────────────────────────────────
# Flask secret key — CHANGE THIS in production (use a long random string)
NEXUSAI_SECRET_KEY=change-me-in-production

# Port the dashboard web UI listens on
DASHBOARD_PORT=5000

# ── Database ────────────────────────────────────────────────────────────────
# SQLAlchemy connection URL (default: SQLite in ./data/)
# For PostgreSQL: postgresql://user:password@host:5432/nexusai
DATABASE_URL=sqlite:///data/nexusai.db

# ── Control Plane ───────────────────────────────────────────────────────────
# Port the control plane API listens on
CONTROL_PLANE_PORT=8000
# Optional API token for control-plane auth (leave empty to disable auth enforcement)
CONTROL_PLANE_API_TOKEN=
# Cloud context egress policy for scheduler cloud backends: allow|redact|block
NEXUSAI_CLOUD_CONTEXT_POLICY=allow
# Worker routing/latency scoring tuning
NEXUSAI_WORKER_LATENCY_EMA_ALPHA=0.30
NEXUSAI_WORKER_DEFAULT_LATENCY_MS=800
# GitHub webhook replay/timestamp protections
NEXUSAI_GITHUB_WEBHOOK_REQUIRE_DELIVERY_ID=1
NEXUSAI_GITHUB_WEBHOOK_MAX_SKEW_SECONDS=300
NEXUSAI_GITHUB_WEBHOOK_REQUIRE_DATE_HEADER=0
NEXUSAI_GITHUB_WEBHOOK_DEDUP_TTL_SECONDS=86400
# Optional per-endpoint hardening overrides (examples):
# CP_MAX_BODY_BYTES_CHAT_MESSAGES=200000
# CP_RATE_LIMIT_CHAT_MESSAGES_COUNT=120
# CP_RATE_LIMIT_CHAT_MESSAGES_WINDOW_SECONDS=60

# ── Worker Agent ────────────────────────────────────────────────────────────
# Port the worker agent listens on
WORKER_AGENT_PORT=8001
# Standalone nexus_worker config path
NEXUS_WORKER_CONFIG_PATH=nexus_worker/config.yaml.example
# Cloud context egress policy for standalone nexus_worker: allow|redact|block
NEXUS_WORKER_CLOUD_CONTEXT_POLICY=redact
# Optional local vLLM model names (comma-separated) for discovery
VLLM_MODELS=

# ── LLM Backends ────────────────────────────────────────────────────────────
# Cloud keys are preferred in Dashboard Settings -> API Keys (encrypted DB storage).
# Environment variables below are optional fallback only.

# OpenAI (fallback)
OPENAI_API_KEY=

# Anthropic Claude (fallback)
ANTHROPIC_API_KEY=

# Google Gemini (fallback)
GEMINI_API_KEY=

# ── Blue/Green Deploy Controls (Dashboard Settings -> Deploy tab) ─────────
# Disabled by default; enable only after validating blue/green runtime.
NEXUSAI_DEPLOY_ENABLE=0
NEXUSAI_DEPLOY_STRATEGY=bluegreen
# Example:
# NEXUSAI_DEPLOY_RUN_CMD=docker run --rm -e NEXUSAI_DEPLOY_STRATEGY=bluegreen -e NEXUSAI_BLUEGREEN_SWITCH_CMD=./scripts/switch-dashboard-color.sh -e NEXUSAI_COMPOSE_PROJECT_NAME=nexusai -e NEXUSAI_LEGACY_DATA_VOLUME=nexusai_nexus-data -v /var/run/docker.sock:/var/run/docker.sock -v /opt/NexusAI:/opt/NexusAI -w /opt/NexusAI docker:27-cli sh -lc "sh ./scripts/deploy-bluegreen.sh"
NEXUSAI_DEPLOY_RUN_CMD=
# Switch command used by deploy-bluegreen.sh
NEXUSAI_BLUEGREEN_SWITCH_CMD=./scripts/switch-dashboard-color.sh
